#!/usr/bin/env bash
###############################################################################
# mtpx — CLI-утилита для управления MTProto Proxy (v4: один контейнер = один пользователь)
#
# Архитектура: каждый пользователь = отдельный контейнер для каждого домена.
# ya.ru + alice → mtproto-ya-ru-alice → SECRET=ee79612e7275...
# ya.ru + bob   → mtproto-ya-ru-bob   → SECRET=ee79612e7275...
###############################################################################
set -euo pipefail

MTPX_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
export MTPX_ROOT

# shellcheck source=lib/util.sh
source "${MTPX_ROOT}/lib/util.sh"
# shellcheck source=lib/config.sh
source "${MTPX_ROOT}/lib/config.sh"
# shellcheck source=lib/secret.sh
source "${MTPX_ROOT}/lib/secret.sh"
# shellcheck source=lib/domain.sh
source "${MTPX_ROOT}/lib/domain.sh"
# shellcheck source=lib/docker.sh
source "${MTPX_ROOT}/lib/docker.sh"
# shellcheck source=lib/monitor.sh
source "${MTPX_ROOT}/lib/monitor.sh"
# shellcheck source=lib/status.sh
source "${MTPX_ROOT}/lib/status.sh"
# shellcheck source=lib/user.sh
source "${MTPX_ROOT}/lib/user.sh"

# ─────────────────────────────────────────────────────────────────────────────
# usage
# ─────────────────────────────────────────────────────────────────────────────
usage() {
  cat <<'EOF'
mtpx v4 — MTProto Proxy (один контейнер = один пользователь)

Использование:
  mtpx <command> [subcommand] [args...]

Команды:
  init                          Инициализация
  apply                         Запустить все контейнеры
  status                        Сводка состояния
  doctor                        Диагностика
  inspect                       Детали всех контейнеров

  domain add <domain>           Создать домен + контейнеры для всех пользователей
  domain remove <domain>        Удалить домен + все контейнеры
  domain list                   Все домены
  domain links                  Все ссылки (все пользователи, все домены)
  domain restart <domain>       Перезапустить все контейнеры домена
  domain stop <domain>          Остановить все контейнеры домена
  domain start <domain>         Запустить все контейнеры домена
  domain logs <domain> [n]      Логи всех контейнеров домена

  user add <username>           Создать пользователя + контейнеры для всех доменов
  user remove <username>        Удалить пользователя + все контейнеры
  user list                     Список пользователей
  user show <username> [ip]     Карточка пользователя со ссылками
  user link <username> [domain] Ссылка tg://
  user links <username>         Все ссылки пользователя
  user revoke <username>        Отозвать секреты
  user rotate <username>        Перегенерировать секреты

  secrets clear                 Удалить все секреты
  stop                          Остановить все
  restart                       Перезапустить все
  monitor                       Мониторинг
  version                       Версия
  help                          Справка

Примеры:
  mtpx init
  mtpx domain add ya.ru
  mtpx user add alice
  mtpx user add bob
  mtpx user show alice        # все ссылки alice
  mtpx domain list            # все домены
EOF
}

version() {
  echo "mtpx v4.0.0 (one-container-per-user)"
}

# ─────────────────────────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────────────────────────
cmd_init() {
  log_step "Инициализация mtpx v4..."
  echo ""

  ensure_dirs
  domains_init
  users_init
  runtime_init
  secrets_init
  chmod_sensitive

  echo ""
  log_info "Проект инициализирован"
  echo ""
  echo "  Структура:"
  echo "  ├── config/"
  echo "  │   └── domains.txt        — список доменов"
  echo "  ├── state/"
  echo "  │   ├── users.csv          — пользователи"
  echo "  │   ├── secrets.csv        — секреты"
  echo "  │   └── runtime.env        — runtime"
  echo "  └── lib/                    — модули"
  echo ""
  echo "  Следующие шаги:"
  echo "  1. mtpx domain add ya.ru      — создать домен"
  echo "  2. mtpx user add alice        — создать пользователя"
  echo "  3. mtpx user add bob          — ещё одного"
  echo "  4. mtpx user show alice       — получить ссылки"
}

cmd_apply() {
  log_step "Применение конфигурации..."
  log_warn "В v4 каждый контейнер создаётся при добавлении пользователя или домена"
  log_info "Для перезапуска всех: mtpx restart"
}

cmd_status() {
  status_full
}

cmd_doctor() {
  echo ""
  echo "╔═════════════════════════════════════════════╗"
  echo "║         mtpx doctor                         ║"
  echo "╠═════════════════════════════════════════════╣"

  local issues=0

  echo "║"
  echo "║  Зависимости:"
  local cmds=(docker openssl xxd curl)
  for cmd in "${cmds[@]}"; do
    if command -v "$cmd" &>/dev/null; then
      local ver=""
      case "$cmd" in
        docker) ver=$(docker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1) ;;
        openssl) ver=$(openssl version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1) ;;
      esac
      printf "║    ✅ %-12s v%s\n" "$cmd" "$ver"
    else
      printf "║    ❌ %-12s НЕ НАЙДЕН\n" "$cmd"
      issues=$(( issues + 1 ))
    fi
  done

  echo "║"
  echo "║  Структура:"
  for f in "${DOMAINS_FILE}" "${USERS_FILE}" "${SECRETS_FILE}" "${RUNTIME_FILE}"; do
    if [[ -f "$f" ]]; then
      printf "║    ✅ %-30s\n" "$(basename "$f")"
    else
      printf "║    ❌ %-30s отсутствует\n" "$(basename "$f")"
      issues=$(( issues + 1 ))
    fi
  done

  echo "║"
  echo "║  Контейнеры:"
  if command -v docker &>/dev/null; then
    local running total
    running=$(count_running_proxies 2>/dev/null || echo "0")
    total=$(count_all_proxies 2>/dev/null || echo "0")
    echo "║    Запущено:    ${running}"
    echo "║    Всего:       ${total}"
  else
    echo "║    ❌ Docker не доступен"
    issues=$(( issues + 1 ))
  fi

  echo "║"
  echo "║  Права файлов:"
  for f in "${SECRETS_FILE}" "${USERS_FILE}" "${RUNTIME_FILE}"; do
    if [[ -f "$f" ]]; then
      local perms
      perms=$(stat -c '%a' "$f" 2>/dev/null || stat -f '%Lp' "$f" 2>/dev/null || echo "?")
      if [[ "$perms" == "600" ]]; then
        printf "║    ✅ %-20s %s\n" "$(basename "$f")" "$perms"
      else
        printf "║    ⚠️  %-20s %s (рекомендуется 600)\n" "$(basename "$f")" "$perms"
      fi
    fi
  done

  echo "║"
  if (( issues == 0 )); then
    echo "║  Итог: ✅ Проблем не найдено"
  else
    echo "║  Итог: ⚠️  Найдено проблем: ${issues}"
  fi
  echo "╚═════════════════════════════════════════════╝"
}

cmd_inspect() {
  echo ""
  echo "╔═════════════════════════════════════════════╗"
  echo "║  Контейнеры                                 ║"
  echo "╠═════════════════════════════════════════════╣"

  docker ps -a --format '{{.Names}}' 2>/dev/null | grep '^mtproto-' | while IFS= read -r cname; do
    local cstatus port
    cstatus=$(docker_container_status "$cname")
    port=$(docker_container_port "$cname" 2>/dev/null || echo "-")

    echo "║  ${cname}:"
    echo "║    Статус:  ${cstatus}"
    echo "║    Порт:    ${port}"

    # Логи (последние 2 строки)
    local logs
    logs=$(docker logs --tail 2 "$cname" 2>&1 || echo "нет логов")
    echo "$logs" | while IFS= read -r line; do
      printf "║    %s\n" "${line:0:55}"
    done
    echo "║"
  done

  echo "╚═════════════════════════════════════════════╝"
}

# ─────────────────────────────────────────────────────────────────────────────
# Dispatchers
# ─────────────────────────────────────────────────────────────────────────────
cmd_domain() {
  local sub="${1:-}"
  shift || true

  case "$sub" in
    add)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain add <domain>"; return 1; }
      domain_add "$@"
      ;;
    remove|rm)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain remove <domain>"; return 1; }
      domain_remove "$1"
      ;;
    list|ls)
      domain_list
      ;;
    links)
      domain_links_all "$@"
      ;;
    restart)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain restart <domain>"; return 1; }
      domain_restart "$1"
      ;;
    stop)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain stop <domain>"; return 1; }
      domain_stop "$1"
      ;;
    start)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain start <domain>"; return 1; }
      domain_start "$1"
      ;;
    logs)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain logs <domain>"; return 1; }
      domain_logs "$@"
      ;;
    *)
      log_error "Неизвестная подкоманда: domain $sub"
      echo "  Доступные: add, remove, list, links, restart, stop, start, logs"
      return 1
      ;;
  esac
}

cmd_user() {
  local sub="${1:-}"
  shift || true

  case "$sub" in
    add)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user add <username>"; return 1; }
      user_add "$@"
      ;;
    remove|rm)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user remove <username>"; return 1; }
      user_remove "$1"
      ;;
    list|ls)
      user_list
      ;;
    show)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user show <username>"; return 1; }
      user_show "$@"
      ;;
    link)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user link <username>"; return 1; }
      user_link "$@"
      ;;
    links)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user links <username>"; return 1; }
      domain_links_for_user "$1"
      ;;
    revoke)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user revoke <username>"; return 1; }
      user_revoke "$1"
      ;;
    rotate)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user rotate <username>"; return 1; }
      user_rotate "$1"
      ;;
    *)
      log_error "Неизвестная подкоманда: user $sub"
      echo "  Доступные: add, remove, list, show, link, links, revoke, rotate"
      return 1
      ;;
  esac
}

cmd_secrets() {
  local sub="${1:-}"
  shift || true

  case "$sub" in
    clear)
      if [[ ! -f "${SECRETS_FILE}" ]]; then
        log_info "Файл секретов не существует"
        return 0
      fi
      local count
      count=$(secret_count 2>/dev/null || echo "0")
      if (( count == 0 )); then
        log_info "Секретов нет"
        return 0
      fi
      log_step "Удаление всех секретов (${count} записей)..."
      atomic_write "${SECRETS_FILE}" "id,secret,type,domain,username,created_at,expires_at,status,comment"
      log_info "Все секреты удалены"
      ;;
    *)
      log_error "Неизвестная подкоманда: secrets $sub"
      echo "  Доступные: clear"
      return 1
      ;;
  esac
}

cmd_stop() {
  stop_all
}

cmd_restart() {
  restart_all
}

cmd_monitor() {
  monitor_summary
}

# ─────────────────────────────────────────────────────────────────────────────
# main
# ─────────────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)      cmd_init "$@" ;;
    apply)     cmd_apply "$@" ;;
    status)    cmd_status "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    inspect)   cmd_inspect "$@" ;;
    domain)    cmd_domain "$@" ;;
    user)      cmd_user "$@" ;;
    secrets)   cmd_secrets "$@" ;;
    stop)      cmd_stop "$@" ;;
    restart)   cmd_restart "$@" ;;
    monitor)   cmd_monitor "$@" ;;
    version)   version ;;
    help|--help|-h)  usage ;;
    *)
      log_error "Неизвестная команда: $cmd"
      echo ""
      usage
      return 1
      ;;
  esac
}

main "$@"
