#!/usr/bin/env bash
###############################################################################
# mtpx — CLI-утилита для управления MTProto Proxy (v2: multi-proxy)
#
# Архитектура: каждый домен = отдельный контейнер со своим секретом.
# Пользователи получают разные ссылки для разных доменов.
#
#   ya.ru       → mtproto-ya-ru       → SECRET=ee79612e7275...
#   google.com  → mtproto-google-com  → SECRET=ee676f6f676c...
#   cloud.com   → mtproto-cloud-com   → SECRET=ee636c6f7564...
###############################################################################
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Определяем корень проекта и загружаем модули
# ─────────────────────────────────────────────────────────────────────────────
MTPX_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
export MTPX_ROOT

# shellcheck source=lib/util.sh
source "${MTPX_ROOT}/lib/util.sh"
# shellcheck source=lib/config.sh
source "${MTPX_ROOT}/lib/config.sh"
# shellcheck source=lib/secret.sh
source "${MTPX_ROOT}/lib/secret.sh"
# shellcheck source=lib/domain.sh
source "${MTPX_ROOT}/lib/domain.sh"
# shellcheck source=lib/docker.sh
source "${MTPX_ROOT}/lib/docker.sh"
# shellcheck source=lib/monitor.sh
source "${MTPX_ROOT}/lib/monitor.sh"
# shellcheck source=lib/status.sh
source "${MTPX_ROOT}/lib/status.sh"
# shellcheck source=lib/user.sh
source "${MTPX_ROOT}/lib/user.sh"
# shellcheck source=lib/config_proxy.sh
source "${MTPX_ROOT}/lib/config_proxy.sh"

# ─────────────────────────────────────────────────────────────────────────────
# usage — справка
# ─────────────────────────────────────────────────────────────────────────────
usage() {
  cat <<'EOF'
mtpx v3 — MTProto Proxy (multi-user, multi-domain)

Использование:
  mtpx <command> [subcommand] [args...]

Команды:
  init                          Инициализация проекта
  apply [domain]                Запустить все домены (или один)
  status                        Сводка состояния
  doctor                        Диагностика
  inspect [domain]              Детали контейнера

  domain add <domain>           Создать домен + контейнер + секреты
  domain remove <domain>        Удалить домен + контейнер
  domain list                   Все домены
  domain links                  Все ссылки
  domain restart <domain>       Перезапустить контейнер
  domain stop <domain>          Остановить контейнер
  domain start <domain>         Запустить контейнер
  domain logs <domain> [n]      Логи

  user add <username>           Создать пользователя + секреты для всех доменов
  user remove <username>        Удалить пользователя + все секреты
  user list                     Список пользователей
  user link <username> [domain] Ссылка tg:// (все домены или конкретный)
  user links <username>         Все ссылки пользователя
  user revoke <username>        Отозвать секреты (без удаления)
  user rotate <username>        Перегенерировать секреты

  migrate                       Миграция данных (v2→v3)
  stop                          Остановить все
  restart                       Перезапустить все
  monitor                       Мониторинг
  version                       Версия
  help                          Справка

Примеры:
  mtpx init
  mtpx domain add ya.ru
  mtpx domain add google.com
  mtpx user add alice
  mtpx user add bob
  mtpx user link alice        # все ссылки alice
  mtpx user link alice ya.ru  # ссылка alice для ya.ru
  mtpx apply
EOF
}

# ─────────────────────────────────────────────────────────────────────────────
# version
# ─────────────────────────────────────────────────────────────────────────────
version() {
  echo "mtpx v3.0.0 (multi-user)"
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_init — инициализация проекта
# ─────────────────────────────────────────────────────────────────────────────
cmd_init() {
  log_step "Инициализация mtpx v3..."
  echo ""

  ensure_dirs
  domains_init
  users_init
  runtime_init
  secrets_init
  chmod_sensitive

  echo ""
  log_info "Проект инициализирован"
  echo ""
  echo "  Структура:"
  echo "  ├── config/"
  echo "  │   ├── domains.txt        — список доменов"
  echo "  │   └── proxy-*.py         — конфиги прокси (автоматические)"
  echo "  ├── state/"
  echo "  │   ├── users.csv          — пользователи"
  echo "  │   └── secrets.csv        — секреты (user+domain)"
  echo "  │   └── runtime.env        — runtime параметры"
  echo "  └── lib/                    — модули"
  echo ""
  echo "  Следующие шаги:"
  echo "  1. mtpx domain add ya.ru      — создать домен"
  echo "  2. mtpx user add alice        — создать пользователя"
  echo "  3. mtpx user add bob          — ещё одного"
  echo "  4. mtpx user link alice       — получить ссылки для alice"
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_apply — запустить все домены (или один конкретный)
# ─────────────────────────────────────────────────────────────────────────────
cmd_apply() {
  local domain="${1:-}"
  if [[ -n "$domain" ]]; then
    apply_single "$domain"
  else
    apply_all
  fi
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_status — сводка состояния
# ─────────────────────────────────────────────────────────────────────────────
cmd_status() {
  status_full
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_doctor — диагностика
# ─────────────────────────────────────────────────────────────────────────────
cmd_doctor() {
  echo ""
  echo "╔═════════════════════════════════════════════╗"
  echo "║         mtpx doctor                         ║"
  echo "╠═════════════════════════════════════════════╣"

  local issues=0

  # Зависимости
  echo "║"
  echo "║  Зависимости:"
  local cmds=(docker openssl xxd curl)
  for cmd in "${cmds[@]}"; do
    if command -v "$cmd" &>/dev/null; then
      local ver=""
      case "$cmd" in
        docker) ver=$(docker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1) ;;
        openssl) ver=$(openssl version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1) ;;
      esac
      printf "║    ✅ %-12s v%s\n" "$cmd" "$ver"
    else
      printf "║    ❌ %-12s НЕ НАЙДЕН\n" "$cmd"
      issues=$(( issues + 1 ))
    fi
  done

  # Структура
  echo "║"
  echo "║  Структура:"
  for f in "${DOMAINS_FILE}" "${SECRETS_FILE}" "${RUNTIME_FILE}"; do
    if [[ -f "$f" ]]; then
      printf "║    ✅ %-30s\n" "$(basename "$f")"
    else
      printf "║    ❌ %-30s отсутствует\n" "$(basename "$f")"
      issues=$(( issues + 1 ))
    fi
  done

  # Docker-контейнеры
  echo "║"
  echo "║  Контейнеры:"
  if command -v docker &>/dev/null; then
    local running total
    running=$(count_running_proxies 2>/dev/null || echo "0")
    total=$(count_all_proxies 2>/dev/null || echo "0")
    echo "║    Запущено:    ${running}"
    echo "║    Всего:       ${total}"
  else
    echo "║    ❌ Docker не доступен"
    issues=$(( issues + 1 ))
  fi

  # Домены
  echo "║"
  echo "║  Домены:"
  if [[ -f "${DOMAINS_FILE}" ]]; then
    local domain_count
    domain_count=$(domain_list_raw 2>/dev/null | wc -l)
    echo "║    В списке:    ${domain_count}"
  else
    echo "║    ℹ️  Не инициализированы"
  fi

  # Права файлов
  echo "║"
  echo "║  Права файлов:"
  for f in "${SECRETS_FILE}" "${RUNTIME_FILE}"; do
    if [[ -f "$f" ]]; then
      local perms
      perms=$(stat -c '%a' "$f" 2>/dev/null || stat -f '%Lp' "$f" 2>/dev/null || echo "?")
      if [[ "$perms" == "600" ]]; then
        printf "║    ✅ %-20s %s\n" "$(basename "$f")" "$perms"
      else
        printf "║    ⚠️  %-20s %s (рекомендуется 600)\n" "$(basename "$f")" "$perms"
      fi
    fi
  done

  # Итог
  echo "║"
  if (( issues == 0 )); then
    echo "║  Итог: ✅ Проблем не найдено"
  else
    echo "║  Итог: ⚠️  Найдено проблем: ${issues}"
  fi
  echo "╚═════════════════════════════════════════════╝"
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_inspect — детальная информация о контейнере
# ─────────────────────────────────────────────────────────────────────────────
cmd_inspect() {
  local domain="${1:-}"

  if [[ -n "$domain" ]]; then
    _inspect_single "$domain"
  else
    _inspect_all
  fi
}

_inspect_single() {
  local domain="$1"
  local cname
  cname=$(container_name_for_domain "$domain")

  echo ""
  echo "╔═════════════════════════════════════════════╗"
  echo "║  mtpx inspect: ${domain}"
  echo "╠═════════════════════════════════════════════╣"

  if ! docker_container_exists "$cname"; then
    echo "║  Контейнер не создан"
    echo "╚═════════════════════════════════════════════╝"
    return 0
  fi

  _inspect_container "$cname" "$domain"
}

_inspect_all() {
  if [[ ! -f "${DOMAINS_FILE}" ]]; then
    echo "  Нет доменов"
    return 0
  fi

  local first=true
  while IFS= read -r domain || [[ -n "$domain" ]]; do
    domain=$(printf '%s' "$domain" | tr -d '\r')
    [[ -z "$domain" ]] && continue
    [[ "$domain" == "domain" ]] && continue

    if $first; then first=false; else echo ""; fi
    _inspect_single "$domain"
  done < "${DOMAINS_FILE}"
}

_inspect_container() {
  local cname="$1" domain="$2"

  local info state started image
  info=$(docker inspect "$cname" 2>/dev/null || echo "{}")
  state=$(echo "$info" | grep -oP '"Status":\s*"\K[^"]+' | head -1 || echo "unknown")
  started=$(echo "$info" | grep -oP '"StartedAt":\s*"\K[^"]+' | head -1 || echo "unknown")
  image=$(echo "$info" | grep -oP '"Image":\s*"\K[^"]+' | head -1 || echo "unknown")

  echo "║  Контейнер:     ${cname}"
  echo "║  Состояние:     ${state}"
  echo "║  Запущен:       ${started}"
  echo "║  Образ:         ${image}"

  # Порты
  local port
  port=$(docker_container_port "$cname" || echo "-")
  echo "║  Порт:          ${port}"

  # Секрет
  local masked
  masked=$(secrets_masked_for_domain "$domain" || echo "-")
  echo "║  Secret:        ${masked}"

  # Логи
  echo "║  Последние логи:"
  local logs
  logs=$(docker logs --tail 3 "$cname" 2>&1 || echo "нет логов")
  echo "$logs" | while IFS= read -r line; do
    printf "║    %s\n" "${line:0:55}"
  done

  echo "╚═════════════════════════════════════════════╝"
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_domain — диспетчер подкоманд domain
# ─────────────────────────────────────────────────────────────────────────────
cmd_domain() {
  local sub="${1:-}"
  shift || true

  case "$sub" in
    add)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain add <domain>"; return 1; }
      add_domain_to_list "$1"
      domain_add "$@"
      ;;
    remove|rm)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain remove <domain>"; return 1; }
      domain_remove "$1"
      remove_domain_from_list "$1"
      ;;
    list|ls)
      domain_list
      ;;
    link)
      log_error "Используйте: mtpx user link <username> [domain]"
      return 1
      ;;
    links)
      domain_links_all "$@"
      ;;
    restart)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain restart <domain>"; return 1; }
      domain_restart "$1"
      ;;
    stop)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain stop <domain>"; return 1; }
      domain_stop "$1"
      ;;
    start)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain start <domain>"; return 1; }
      domain_start "$1"
      ;;
    logs)
      [[ $# -gt 0 ]] || { log_error "Укажите домен: mtpx domain logs <domain>"; return 1; }
      domain_logs "$@"
      ;;
    *)
      log_error "Неизвестная подкоманда: domain $sub"
      echo "  Доступные: add, remove, list, links, restart, stop, start, logs"
      return 1
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_user — диспетчер подкоманд user
# ─────────────────────────────────────────────────────────────────────────────
cmd_user() {
  local sub="${1:-}"
  shift || true

  case "$sub" in
    add)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user add <username>"; return 1; }
      user_add "$@"
      # После добавления пользователя — перезапускаем контейнеры
      if [[ -f "${DOMAINS_FILE}" ]]; then
        docker_config_sync_all
      fi
      ;;
    remove|rm)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user remove <username>"; return 1; }
      user_remove "$1"
      # После удаления — перезапускаем контейнеры
      docker_config_sync_all
      ;;
    list|ls)
      user_list
      ;;
    link)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user link <username>"; return 1; }
      user_link "$@"
      ;;
    links)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user links <username>"; return 1; }
      domain_links_for_user "$(user_get_id "$1")"
      ;;
    revoke)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user revoke <username>"; return 1; }
      user_revoke "$1"
      docker_config_sync_all
      ;;
    rotate)
      [[ $# -gt 0 ]] || { log_error "Укажите имя: mtpx user rotate <username>"; return 1; }
      user_rotate "$1"
      docker_config_sync_all
      ;;
    *)
      log_error "Неизвестная подкоманда: user $sub"
      echo "  Доступные: add, remove, list, link, links, revoke, rotate"
      return 1
      ;;
  esac
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_stop — остановить все прокси
# ─────────────────────────────────────────────────────────────────────────────
cmd_stop() {
  stop_all
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_restart — перезапустить все прокси
# ─────────────────────────────────────────────────────────────────────────────
cmd_restart() {
  restart_all
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_monitor — эвристический мониторинг
# ─────────────────────────────────────────────────────────────────────────────
cmd_monitor() {
  monitor_summary
}

# ─────────────────────────────────────────────────────────────────────────────
# cmd_migrate — миграция данных
# ─────────────────────────────────────────────────────────────────────────────
cmd_migrate() {
  log_step "Миграция данных..."
  migrate_secrets
  log_info "Миграция завершена"
}

# ─────────────────────────────────────────────────────────────────────────────
# main — диспетчер команд
# ─────────────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)      cmd_init "$@" ;;
    apply)     cmd_apply "$@" ;;
    status)    cmd_status "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    inspect)   cmd_inspect "$@" ;;
    domain)    cmd_domain "$@" ;;
    user)      cmd_user "$@" ;;
    migrate)   cmd_migrate "$@" ;;
    stop)      cmd_stop "$@" ;;
    restart)   cmd_restart "$@" ;;
    monitor)   cmd_monitor "$@" ;;
    version)   version ;;
    help|--help|-h)  usage ;;
    *)
      log_error "Неизвестная команда: $cmd"
      echo ""
      usage
      return 1
      ;;
  esac
}

main "$@"
